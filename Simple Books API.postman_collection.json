    {
      "name": "API status - Verify status is 200 OK",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "console.log(response);\r",
              "\r",
              "pm.test(\"Status is OK\", () => {\r",
              "    pm.expect(response.status).to.eql(\"OK\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "status"
          ]
        }
      },
      "response": []
    },
    {
      "name": "List of books - retrieve first available non-fiction book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "const nonFictionBooks = response.filter((book) => book.available === true);\r",
              "\r",
              "const book = (nonFictionBooks[0]);\r",
              "\r",
              "if (book) {\r",
              "    pm.collectionVariables.set(\"bookId\", book.id);\r",
              "}\r",
              "\r",
              "pm.test(\"First available non-fiction book found\", () => {\r",
              "    pm.expect(book).to.be.an('object');\r",
              "    pm.expect(book.available).to.eql(true);\r",
              "    pm.expect(book.type).to.eql(\"non-fiction\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books?type=non-fiction",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "books"
          ],
          "query": [
            {
              "key": "type",
              "value": "non-fiction"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get single book - retrieve specified non-fiction book",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Desired non-fiction book in stock\", function () {\r",
              "    pm.expect(response.name).to.be.eql(\"Untamed\");\r",
              "    pm.expect(response[\"current-stock\"]).to.be.above(0);\r",
              "    pm.expect(response.type).to.be.eql(\"non-fiction\")\r",
              "}); "
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/books/:bookId",
