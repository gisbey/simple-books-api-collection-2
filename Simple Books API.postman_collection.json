    {
      "name": "Get all book orders - verify ordered book on list",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "const orderId = pm.collectionVariables.get(\"orderId\");\r",
              "const order = Array.isArray(response) ? response.find(o => o.id === orderId) : response;\r",
              "\r",
              "pm.collectionVariables.set(\"customerName\", order.customerName);\r",
              "\r",
              "pm.test(\"Order present\", function () {\r",
              "    pm.expect(order.id).to.eql(orderId);\r",
              "    pm.expect(order.quantity).to.eql(1);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
